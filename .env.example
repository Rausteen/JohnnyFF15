# Supabase Configuration
# Replace these with your actual Supabase project credentials
# Go to https://supabase.com -> Your project -> Settings -> API
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Riot Games API
# Get your API key at https://developer.riotgames.com/
VITE_RIOT_API_KEY=your_riot_api_key

# Discord Webhook (optional)
# Create a webhook in your Discord server: Server Settings -> Integrations -> Webhooks
VITE_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Site URL (for Discord notifications links)
VITE_SITE_URL=https://johnnyff15.com
